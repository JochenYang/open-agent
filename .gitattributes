# Auto detect text files and perform LF normalization
* text=auto

# Scripts and config files
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown and text files
*.md text diff=markdown
*.json text
*.yaml text
*.yml text

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.svg text
