    "markdownListItem": { "dark": "primary", "light": "primary" },
    "markdownListEnumeration": { "dark": "accent", "light": "accent" },
    "markdownImage": { "dark": "info", "light": "info" },
    "markdownImageText": { "dark": "accent", "light": "accent" },
    "markdownCodeBlock": { "dark": "textBright", "light": "textLightDark" },
    "syntaxComment": { "dark": "synComment", "light": "synComment" },
    "syntaxKeyword": { "dark": "synKeyword", "light": "synKeyword" },
    "syntaxFunction": { "dark": "synFunction", "light": "synFunction" },
    "syntaxVariable": { "dark": "synVariable", "light": "synVariable" },
    "syntaxString": { "dark": "synString", "light": "synString" },
    "syntaxNumber": { "dark": "synNumber", "light": "synNumber" },
    "syntaxType": { "dark": "synType", "light": "synType" },
    "syntaxOperator": { "dark": "synKeyword", "light": "synKeyword" },
