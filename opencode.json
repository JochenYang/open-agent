{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "行者",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "permission": {
    "external_directory": "allow",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rm -rf *": "ask",
      "rm -fr *": "ask",
      "del *": "ask",
      "ri *": "ask",
      "rd *": "ask",
      "rmdir *": "ask",
      "erase *": "ask",
      "Remove-Item *": "ask",
      "Clear-Item *": "ask",
      "unlink *": "ask",
      "shred *": "ask",
      "git rm*": "ask",
      "cmdkey /delete*": "ask"
    }
  }
}
