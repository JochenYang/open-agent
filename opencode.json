{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [
    "~/.config/opencode/rules/character.md",
    "~/.config/opencode/AGENTS.md",
    "~/.config/opencode/rules/coding-standards.md",
    "~/.config/opencode/rules/product-workflow.md",
    "~/.config/opencode/rules/security.md",
    "~/.config/opencode/rules/context-compression.md",
    "~/.config/opencode/rules/evidence-first.md"
  ],
  "lsp": true,
  "skills": {
    "paths": [
      "~/.config/opencode/forge-skills"
    ]
  },
  "mcp": {
    "context7": {
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true,
      "type": "local"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "interleaved-thinking": {
      "command": [
        "npx",
        "-y",
        "@jochenyang/interleaved-thinking"
      ],
      "enabled": true,
      "type": "local"
    },
    "time-mcp": {
      "command": [
        "npx",
        "-y",
        "time-mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "Clear-Item *": "ask",
      "Remove-Item *": "ask",
      "cmdkey /delete*": "ask",
      "del *": "ask",
      "erase *": "ask",
      "git rm*": "ask",
      "rd *": "ask",
      "ri *": "ask",
      "rm *": "ask",
      "rm -fr *": "ask",
      "rm -rf *": "ask",
      "rmdir *": "ask",
      "shred *": "ask",
      "unlink *": "ask"
    },
    "external_directory": "allow"
  },
  "agent": {
    "build": {
      "permission": {
        "external_directory": "allow"
      }
    },
    "plan": {
      "permission": {
        "external_directory": "allow"
      }
    },
    "general": {
      "permission": {
        "external_directory": "allow"
      }
    },
    "forge": {
      "permission": {
        "external_directory": "allow"
      }
    }
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.6",
    "./plugins/notification-plugin.js",
    "./plugins/forge-plugin.js",
    "./plugins/opencode-mission.js"
  ],
  "provider": {
    "minimax-国内": {
      "models": {
        "coding-plan": {
          "id": "MiniMax-M3",
          "limit": {
            "context": 1000000,
            "output": 204800
          },
          "name": "MiniMax-M3"
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}",
        "baseURL": "https://api.minimaxi.com/v1"
      }
    }
  }
}
