{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "行者",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "permission": {
    "bash": {
      "git push*": "ask",
      "npm publish*": "ask",
      "pnpm publish*": "ask",
      "yarn publish*": "ask",
      "pip install*": "ask",
      "rm *": "ask",
      "rm -rf *": "ask",
      "rm -fr *": "ask",
      "del *": "ask",
      "Remove-Item *": "ask",
      "*": "allow"
    }
  }
}
